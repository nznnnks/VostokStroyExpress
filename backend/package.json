{
  "name": "vostokstroyexpert-backend",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run prisma:generate && node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && nest build",
    "admin:create": "ts-node prisma/create-admin.ts",
    "dev": "npm run start:dev",
    "catalog:import": "ts-node prisma/import-catalog.ts",
    "products:clear": "ts-node prisma/clear-products.ts",
    "seed": "ts-node prisma/seed.ts",
    "start": "nest start",
    "start:dev": "cross-env TS_NODE_PROJECT=tsconfig.json node --watch --watch-path=src -r ts-node/register/transpile-only src/main.ts",
    "start:prod": "node dist/src/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.2",
    "@nestjs/core": "^11.1.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.2",
    "@prisma/client": "^6.6.0",
    "csv-parse": "^5.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.4",
    "@nestjs/testing": "^11.1.2",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.1",
    "cross-env": "^7.0.3",
    "prisma": "^6.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
