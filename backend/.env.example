DATABASE_URL=postgresql://postgres:password@localhost:5432/vostokstroyexpress

# Mail.ru (app password recommended)
MAIL_USER=example@mail.ru
MAIL_PASS=
MAIL_FROM=example@mail.ru
MAIL_SMTP_HOST=smtp.mail.ru
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE=true
MAIL_SMTP_CONNECTION_TIMEOUT_MS=8000
MAIL_SMTP_GREETING_TIMEOUT_MS=8000
MAIL_SMTP_SOCKET_TIMEOUT_MS=10000
MAIL_IMAP_HOST=imap.mail.ru
MAIL_IMAP_PORT=993

# YooKassa test/live credentials
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# URL where YooKassa redirects the buyer after payment confirmation
YOOKASSA_RETURN_URL=http://localhost:4321/checkout?payment=return

# Enable only on public production infrastructure. Keep disabled for local tunnels like ngrok.
YOOKASSA_WEBHOOK_VALIDATE_IP=false
