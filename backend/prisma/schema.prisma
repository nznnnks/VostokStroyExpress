generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  MANAGER
  EDITOR
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum DiscountScope {
  ORDER
  PRODUCT
  CATEGORY
  CLIENT
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum ItemKind {
  PRODUCT
  SERVICE
}

enum OrderStatus {
  NEW
  PENDING_PAYMENT
  PAID
  ASSEMBLY
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CARD
  SBP
  INVOICE
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  phone         String?        @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  role          UserRole       @default(CLIENT)
  status        UserStatus     @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clientProfile ClientProfile?
  cart          Cart?
  orders        Order[]
  orderTemplates OrderTemplate[]
  news          News[]
}

model ClientProfile {
  id                      String      @id @default(uuid()) @db.Uuid
  userId                  String      @unique @db.Uuid
  firstName               String
  lastName                String?
  companyName             String?
  inn                     String?
  contactPhone            String?
  addressLine1            String?
  city                    String?
  postalCode              String?
  comment                 String?
  personalDiscountPercent Decimal?    @db.Decimal(5, 2)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  user                    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  discounts               Discount[]
}

model Category {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  slug        String      @unique
  description String?
  imageUrl    String?
  metaTitle   String?
  metaDescription String?
  metaKeywords String?
  sortOrder   Int         @default(0)
  parentId    String?     @db.Uuid
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  parent      Category?   @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]  @relation("CategoryTree")
  products    Product[]
  discounts   Discount[]
}

model Product {
  id               String        @id @default(uuid()) @db.Uuid
  categoryId       String        @db.Uuid
  slug             String        @unique
  sku              String        @unique
  name             String
  shortDescription String?
  description      String?
  brand            String?
  brandLabel       String?
  country          String?
  type             String?
  price            Decimal       @db.Decimal(12, 2)
  oldPrice         Decimal?      @db.Decimal(12, 2)
  power            Decimal?      @db.Decimal(8, 2)
  volume           Decimal?      @db.Decimal(8, 2)
  rating           String?
  efficiency       String?
  efficiencyClass  String?
  coverage         String?
  acoustics        String?
  filtration       String?
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  images           String[]      @default([])
  stock            Int           @default(0)
  status           ProductStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  category         Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  discounts        Discount[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
}

model Service {
  id               String      @id @default(uuid()) @db.Uuid
  slug             String      @unique
  name             String
  shortDescription String?
  description      String?
  heroTitle        String?
  lead             String?
  detailTitle      String?
  bullets          String[]    @default([])
  detailImages     String[]    @default([])
  deliverables     String[]    @default([])
  imageUrl         String?
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  basePrice        Decimal?    @db.Decimal(12, 2)
  durationHours    Int?
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  cartItems        CartItem[]
  orderItems       OrderItem[]
}

model Discount {
  id              String        @id @default(uuid()) @db.Uuid
  name            String
  code            String?       @unique
  description     String?
  type            DiscountType
  scope           DiscountScope @default(ORDER)
  value           Decimal       @db.Decimal(12, 2)
  isActive        Boolean       @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  productId       String?       @db.Uuid
  categoryId      String?       @db.Uuid
  clientProfileId String?       @db.Uuid
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  clientProfile   ClientProfile? @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  carts           Cart[]
  orders          Order[]
}

model Cart {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @unique @db.Uuid
  appliedDiscountId String?     @db.Uuid
  status            CartStatus  @default(ACTIVE)
  comment           String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  appliedDiscount   Discount?   @relation(fields: [appliedDiscountId], references: [id], onDelete: SetNull)
  items             CartItem[]
}

model CartItem {
  id         String    @id @default(uuid()) @db.Uuid
  cartId     String    @db.Uuid
  productId  String?   @db.Uuid
  serviceId  String?   @db.Uuid
  kind       ItemKind
  quantity   Int       @default(1)
  unitPrice  Decimal   @db.Decimal(12, 2)
  totalPrice Decimal   @db.Decimal(12, 2)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  cart       Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product    Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  service    Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([cartId])
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  orderNumber       String      @unique
  userId            String      @db.Uuid
  templateId        String?     @db.Uuid
  appliedDiscountId String?     @db.Uuid
  status            OrderStatus @default(NEW)
  subtotal          Decimal     @db.Decimal(12, 2)
  discountTotal     Decimal     @default(0) @db.Decimal(12, 2)
  vatTotal          Decimal     @default(0) @db.Decimal(12, 2)
  total             Decimal     @db.Decimal(12, 2)
  deliveryMethod    String?
  deliveryAddress   String?
  contactName       String?
  contactPhone      String?
  comment           String?
  placedAt          DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  template          OrderTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  appliedDiscount   Discount?   @relation(fields: [appliedDiscountId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payments          Payment[]
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @db.Uuid
  productId  String?  @db.Uuid
  serviceId  String?  @db.Uuid
  kind       ItemKind
  title      String
  sku        String?
  imageUrl   String?
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  totalPrice Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  service    Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}

model OrderTemplate {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  title       String
  contactName String
  phone       String
  address     String
  city        String?
  postalCode  String?
  comment     String?
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  orderId        String        @db.Uuid
  provider       String?
  transactionId  String?       @unique
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("RUB")
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model News {
  id            String      @id @default(uuid()) @db.Uuid
  slug          String      @unique
  title         String
  excerpt       String?
  category      String?
  coverImageUrl String?
  metaTitle     String?
  metaDescription String?
  metaKeywords  String?
  contentBlocks String[]    @default([])
  status        NewsStatus  @default(DRAFT)
  publishedAt   DateTime?
  authorId      String?     @db.Uuid
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  author        User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
}
