                          <span class="shrink-0 pt-1 text-[clamp(12px,0.55vw+10px,17px)] leading-none text-[#9a9891]">{article.publishedLabel}</span>
                        </div>
                        <p class={`mt-4 max-w-[52ch] text-[clamp(15px,0.5vw+13px,21px)] leading-[1.28] text-[#30302c] ${index === 1 ? "line-clamp-2" : "line-clamp-3"}`}>{article.text}</p>
                        <div class="mt-auto flex justify-end pt-5">
                          <span class="inline-flex h-12 min-w-[144px] items-center justify-center bg-[#1a1a1a] px-8 text-[clamp(12px,0.4vw+10px,14px)] uppercase tracking-[1.2px] text-white [font-family:'JetBrains_Mono',monospace]">читать</span>
