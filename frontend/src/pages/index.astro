---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader";
import SiteFooter from "../components/SiteFooter";
import ServiceOrderModal from "../components/ServiceOrderModal";
import HeroHomeIsland from "../components/HeroHomeIsland";
import HomeReviewsIsland from "../components/HomeReviewsIsland";
import HomeConsultationIsland from "../components/HomeConsultationIsland";
import GlobalPreloader from "../components/GlobalPreloader.astro";
import {
  blog,
  serviceHrefByTitle,
  services,
  steps,
  trustHighlights,
  trustLogoBottomRow,
  trustLogoDesktopBottomRow,
  trustLogoDesktopTopRow,
  trustLogoTopRow,
} from "../data/home";

const blogTopRow = blog.slice(0, 2);
const blogBottomRow = blog.slice(2, 4);
const mobileBlogLead = blog[0];
const mobileBlogMiddle = blog.slice(1, 3);
const mobileBlogTail = blog[3];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Stayse Engineering</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@400;500&family=Jaldi:wght@400;700&family=JetBrains+Mono:wght@400&family=Manrope:wght@200;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <GlobalPreloader />
    <main class="flex min-h-screen flex-col bg-white text-[#0f0f0e] [font-family:Manrope,'Liberation_Sans',sans-serif]">
      <div class="flex-1">
        <SiteHeader client:load />
        <HeroHomeIsland client:idle />

        <section id="about" class="relative overflow-hidden bg-[#050505] px-3 pt-12 pb-0 text-white sm:px-5 md:pt-18 md:pb-0">
          <div class="absolute inset-0">
            <div class="absolute left-1/2 top-0 h-full w-screen -translate-x-1/2 overflow-hidden">
              <video
                class="absolute inset-0 h-full w-full object-cover object-center brightness-[1.03] md:hidden"
                data-about-video="mobile"
                autoplay
                muted
                loop
                playsinline
                webkit-playsinline
                preload="auto"
                poster="/image/about-trust-mobile.png"
                aria-hidden="true"
              >
                <source src="/video/about-trust.mp4" type="video/mp4" />
              </video>
              <img src="/image/hero-desktop-bg.jpeg" alt="" aria-hidden="true" loading="lazy" decoding="async" class="absolute inset-0 hidden h-full w-full object-cover object-center md:block" />
              <video
                class="absolute inset-0 hidden h-full w-full object-cover md:block"
                data-about-video="desktop"
                autoplay
                muted
                loop
                playsinline
                webkit-playsinline
                preload="auto"
                poster="/image/hero-desktop-bg.jpeg"
                aria-hidden="true"
              >
                <source src="/video/about-trust.mp4" type="video/mp4" />
              </video>
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(7,10,15,0.08)_0%,rgba(8,11,16,0.08)_18%,rgba(8,11,16,0.14)_46%,rgba(8,11,16,0.24)_100%)] md:bg-[linear-gradient(180deg,rgba(7,10,15,0.56)_0%,rgba(8,11,16,0.52)_16%,rgba(8,11,16,0.62)_42%,rgba(8,11,16,0.72)_72%,rgba(8,11,16,0.84)_100%)]" />
            </div>
          </div>
          <div class="relative z-10 left-1/2 w-screen -translate-x-1/2">
            <div class="px-3 sm:px-5 md:px-10 xl:px-12 2xl:px-20">
              <div class="grid gap-4 xl:grid-cols-4 xl:items-stretch xl:gap-6 2xl:gap-8">
                <div class="flex min-h-[118px] flex-col justify-start rounded-[18px] bg-white px-6 py-5 text-[#12120f] md:min-h-[124px] md:px-8 md:py-5 xl:min-h-[132px] xl:justify-between xl:px-10 xl:py-6">
                  <p class="text-[clamp(10px,0.32vw+9px,14px)] uppercase tracking-[0.22em] text-[#7f8ea3] [font-family:'JetBrains_Mono',monospace]">25 лет на российском рынке</p>
                  <h2 class="mt-7 max-w-[12ch] text-[clamp(32px,8vw,46px)] leading-[0.92] tracking-[-0.03em] [font-family:'Cormorant_Garamond',serif] md:mt-0 md:max-w-[14ch] md:text-[clamp(28px,2vw,40px)] md:leading-[0.98] md:tracking-[-0.02em]">ВостокСтройЭксперт</h2>
                </div>
                <div class="flex min-h-[116px] items-center rounded-[18px] bg-white px-6 py-5 text-[#12120f] md:min-h-[124px] md:px-8 md:py-5 xl:col-span-3 xl:min-h-[132px] xl:px-14 2xl:px-16">
                  <p class="max-w-[68ch] text-[clamp(24px,1.55vw,42px)] leading-[1.08] [font-family:'Cormorant_Garamond',serif]">
                    Прецизионный климат-контроль Dantex для элитных резиденций и промышленных объектов высшего класса. Когда тишина становится ощутимой.
                  </p>
                </div>
              </div>
            </div>

            <div class="relative z-10 left-1/2 mt-8 w-screen -translate-x-1/2">
              <div class="px-3 py-10 sm:px-5 md:px-10 xl:px-12 xl:py-12 2xl:px-20">
                <div class="grid grid-cols-2 gap-4 xl:grid-cols-4 xl:gap-6 2xl:gap-8">
                  {trustHighlights.map(({ value, lines }) => (
                    <article class="flex min-h-[128px] flex-col justify-between rounded-[18px] border border-white/10 bg-[linear-gradient(180deg,rgba(89,98,116,0.42)_0%,rgba(68,74,89,0.32)_100%)] px-5 py-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] backdrop-blur-[10px] xl:min-h-[176px] xl:px-7 xl:py-6">
                      <strong class="block text-[clamp(2rem,6vw,3rem)] font-semibold leading-none tracking-[-0.03em] text-[#eef0f4] xl:text-[clamp(2.45rem,2.4vw,3.7rem)]">{value}</strong>
                      <p class="text-[clamp(13px,1.1vw,18px)] font-semibold leading-[0.98] text-[#d7dae1] xl:text-[clamp(17px,0.72vw+13px,26px)]"><span class="block whitespace-nowrap">{lines[0]}</span><span class="block whitespace-nowrap">{lines[1]}</span></p>
                    </article>
                  ))}
                </div>
              </div>

              <div class="relative left-1/2 mt-8 w-screen -translate-x-1/2 sm:mt-10 2xl:mt-12">
                <div class="hidden flex-col gap-4 px-3 sm:flex sm:flex-row sm:items-end sm:justify-between sm:px-4 md:px-6 2xl:px-8">
                  <div class="space-y-4 sm:self-end">
                    <div class="inline-flex min-h-[92px] w-fit items-center rounded-[18px] border border-[#e7e2d9] bg-[linear-gradient(180deg,#ffffff_0%,#f6f3ee_100%)] px-6 py-4 text-[clamp(18px,1vw+14px,28px)] font-semibold text-[#12120f] shadow-[0_10px_24px_rgba(0,0,0,0.08),inset_0_1px_0_rgba(255,255,255,0.8)] xl:px-7">
                      Более 62 брендов нам доверяют
                    </div>
                  </div>
                  <a href="/about" class="inline-flex min-h-[78px] w-full items-center justify-center self-start rounded-[24px] border border-[#e7ddd0] bg-[linear-gradient(180deg,#fffdfa_0%,#f3eee7_100%)] px-8 text-center text-[clamp(18px,1vw+14px,28px)] font-semibold leading-none tracking-[-0.01em] text-[#141310] shadow-[0_16px_36px_rgba(0,0,0,0.14),inset_0_1px_0_rgba(255,255,255,0.92)] transition duration-300 ease-out hover:-translate-y-1 hover:border-[#dbc9aa] hover:bg-[linear-gradient(180deg,#fffefc_0%,#f7f1e7_100%)] hover:shadow-[0_24px_44px_rgba(0,0,0,0.18)] sm:min-h-[92px] sm:w-[320px] sm:self-end">О нас</a>
                </div>
              </div>

              <div class="mt-8 flex flex-col gap-3 px-3 sm:hidden">
                <div class="inline-flex max-w-full flex-col rounded-[18px] border border-[#e7e2d9] bg-[linear-gradient(180deg,#ffffff_0%,#f6f3ee_100%)] px-5 py-3 font-semibold text-[#12120f] shadow-[0_10px_24px_rgba(0,0,0,0.08),inset_0_1px_0_rgba(255,255,255,0.8)]">
                  <span class="text-[22px] leading-[1.05]">Более 62 брендов</span>
                  <span class="mt-1 text-[16px] font-medium leading-[1.1] text-[#6a635a]">нам доверяют</span>
                </div>
              </div>

                <div class="mt-5 bg-white/98 px-0 py-3 xl:py-4 2xl:mt-12">
                  <div class="sm:hidden">
                    <div class="grid grid-cols-2 gap-2 px-3">
                      {[...trustLogoTopRow, ...trustLogoBottomRow].map(({ path, alt }) => (
                        <article class="flex h-[84px] min-w-0 items-center justify-center rounded-[18px] border border-[#f1eee8] bg-white px-3 py-2">
                          <div class="flex h-[52px] w-full items-center justify-center">
                            <img src={path} alt={alt} loading="lazy" decoding="async" class="h-full w-auto max-w-[clamp(120px,34vw,170px)] object-contain object-center" />
                          </div>
                        </article>
                      ))}
                    </div>
                  </div>

                  <div class="hidden sm:block xl:hidden">
                    <div class="space-y-3">
                      <div class="grid grid-cols-4 gap-3">
                      {trustLogoTopRow.map(({ path, alt }) => (
                        <article class="group flex min-h-[112px] items-center justify-center rounded-[18px] border border-[#f1eee8] bg-white px-4 py-3 transition duration-300 ease-out hover:-translate-y-0.5 hover:border-[#e1d3bb] hover:shadow-[0_14px_28px_rgba(0,0,0,0.08)]">
                          <div class="flex h-[clamp(58px,6vw,82px)] w-full items-center justify-center">
                            <img src={path} alt={alt} loading="lazy" decoding="async" class="h-full w-auto max-w-[clamp(172px,16vw,248px)] object-contain object-center transition duration-300 ease-out group-hover:scale-[1.06]" />
                          </div>
                        </article>
                      ))}
                    </div>
                    <div class="grid grid-cols-3 gap-3 sm:mx-auto sm:w-[86%]">
                      {trustLogoBottomRow.map(({ path, alt }) => (
                        <article class="group flex min-h-[112px] items-center justify-center rounded-[18px] border border-[#f1eee8] bg-white px-4 py-3 transition duration-300 ease-out hover:-translate-y-0.5 hover:border-[#e1d3bb] hover:shadow-[0_14px_28px_rgba(0,0,0,0.08)]">
                          <div class="flex h-[clamp(58px,6vw,82px)] w-full items-center justify-center">
                            <img src={path} alt={alt} loading="lazy" decoding="async" class="h-full w-auto max-w-[clamp(172px,16vw,248px)] object-contain object-center transition duration-300 ease-out group-hover:scale-[1.06]" />
                          </div>
                        </article>
                      ))}
                    </div>
                  </div>
                </div>

                <div class="hidden space-y-3 xl:block 2xl:space-y-4">
                  <div class="grid grid-cols-7 gap-3 2xl:gap-4">
                    {trustLogoDesktopTopRow.map(({ path, alt }) => (
                      <article class="group flex h-[112px] min-w-0 items-center justify-center rounded-[18px] border border-[#f1eee8] bg-white px-4 py-3 transition duration-300 ease-out hover:-translate-y-0.5 hover:border-[#e1d3bb] hover:shadow-[0_14px_28px_rgba(0,0,0,0.08)] 2xl:h-[118px] 2xl:px-5">
                        <div class="flex h-[clamp(62px,4.6vw,90px)] w-full items-center justify-center">
                          <img src={path} alt={alt} loading="lazy" decoding="async" class="h-full w-auto max-w-[clamp(180px,11vw,250px)] object-contain object-center transition duration-300 ease-out group-hover:scale-[1.06]" />
                        </div>
                      </article>
                    ))}
                  </div>
                  <div class="mx-auto grid w-[calc(100%-96px)] grid-cols-6 gap-3 2xl:w-[calc(100%-120px)] 2xl:gap-4">
                    {trustLogoDesktopBottomRow.map(({ path, alt }) => (
                      <article class="group flex h-[112px] min-w-0 items-center justify-center rounded-[18px] border border-[#f1eee8] bg-white px-4 py-3 transition duration-300 ease-out hover:-translate-y-0.5 hover:border-[#e1d3bb] hover:shadow-[0_14px_28px_rgba(0,0,0,0.08)] 2xl:h-[118px] 2xl:px-5">
                        <div class="flex h-[clamp(62px,4.6vw,90px)] w-full items-center justify-center">
                          <img src={path} alt={alt} loading="lazy" decoding="async" class="h-full w-auto max-w-[clamp(180px,11vw,250px)] object-contain object-center transition duration-300 ease-out group-hover:scale-[1.06]" />
                        </div>
                      </article>
                    ))}
                  </div>
                </div>
              </div>

              <div class="mt-6 mb-8 px-3 sm:hidden">
                <a href="/about" class="group relative flex min-h-[108px] w-full items-center justify-between overflow-hidden rounded-[18px] border border-[#e3dbcf] bg-[linear-gradient(180deg,#fbf8f3_0%,#f0e9e0_100%)] px-6 py-5 text-[#12120f] shadow-[0_18px_32px_rgba(0,0,0,0.14),inset_0_1px_0_rgba(255,255,255,0.9)] transition duration-300 ease-out hover:-translate-y-0.5 hover:border-[#d7c9b3] hover:shadow-[0_24px_38px_rgba(0,0,0,0.16),inset_0_1px_0_rgba(255,255,255,0.92)] active:translate-y-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#cdb06a]/50 focus-visible:ring-offset-2 focus-visible:ring-offset-[#050505]">
                  <div class="pointer-events-none absolute -right-8 -top-10 h-32 w-32 rounded-full bg-white/75 blur-[28px]" />
                  <div class="relative flex min-w-0 flex-col items-start text-left">
                    <span class="text-[10px] uppercase tracking-[0.28em] text-[#8f8578] [font-family:'JetBrains_Mono',monospace]">о компании</span>
                    <span class="mt-2 text-[clamp(30px,8vw,38px)] leading-[0.92] tracking-[-0.03em] [font-family:'Cormorant_Garamond',serif]">Больше о нас</span>
                  </div>
                </a>
              </div>
            </div>
          </div>
        </section>

        <section id="services" class="px-3 py-12 sm:px-5 md:px-10 md:py-18">
          <div class="mx-auto max-w-[1480px] 2xl:max-w-[1860px]">
            <p class="text-[clamp(12px,0.45vw+10px,17px)] uppercase tracking-[1.5px] text-[#b99863] [font-family:'JetBrains_Mono',monospace]">основные услуги</p>
            <h2 class="mt-3 text-[clamp(32px,3.2vw,72px)] leading-[0.95] [font-family:'Cormorant_Garamond',serif]">Наши услуги</h2>
            <div class="mt-10 grid gap-10 md:grid-cols-2 md:gap-8 xl:grid-cols-3">
              {services.map((service, index) => (
                <article
                  data-service-card
                  data-home-services-reveal
                  data-reveal-delay={index * 120}
                  class="home-services-reveal group relative flex h-full flex-col px-0 transition-transform duration-300 ease-out hover:-translate-y-1"
                >
                  <a href={serviceHrefByTitle[service.title] ?? "/services"} aria-label={`Открыть направление: ${service.title}`} class="absolute inset-0 z-10" />
                  <div class="relative w-full overflow-hidden rounded-none md:mx-auto md:w-full md:max-w-[460px] md:rounded-[22px] xl:max-w-[480px] 2xl:max-w-[520px]">
                    <div class={`pointer-events-none absolute left-1/2 top-[8%] h-[58%] w-[46%] -translate-x-1/2 rounded-full opacity-65 blur-[2px] ${service.accentClassName}`} />
                    <div class={`pointer-events-none absolute bottom-[2%] left-1/3 h-[18%] w-[26%] -translate-x-1/2 rotate-[-8deg] opacity-95 ${service.accentClassName}`} style="clip-path: polygon(0 0, 100% 0, 100% 68%, 0 100%)" />
                    <div class="relative aspect-[1.32] overflow-hidden rounded-none bg-[#f4f1ea] md:aspect-[1.3] md:rounded-[22px]">
                      <video data-service-video muted loop playsInline preload="metadata" poster={service.poster} class="absolute inset-0 hidden h-full w-full object-cover opacity-0 transition duration-500 ease-out md:block group-hover:opacity-100">
                        <source src={service.video} type="video/mp4" />
                      </video>
                      <img src={service.poster} alt="" loading="lazy" decoding="async" width="560" height="560" class="relative z-[1] h-full w-full rounded-none object-cover transition duration-500 ease-out group-hover:scale-[1.02] group-hover:opacity-0 md:rounded-[22px]" />
                      <div class="absolute inset-0 z-[2] bg-[linear-gradient(180deg,rgba(11,12,14,0.16)_0%,rgba(11,12,14,0.18)_26%,rgba(11,12,14,0.36)_52%,rgba(11,12,14,0.72)_100%)] md:hidden" />
                      <div class="absolute inset-x-0 bottom-0 z-[3] px-6 pb-10 pt-12 text-white md:hidden">
                        <h3 class="max-w-[12ch] text-[clamp(1.9rem,7.2vw,3rem)] uppercase leading-[0.88] tracking-[-0.03em] [font-family:'Cormorant_Garamond',serif]">{service.title}</h3>
                        <p class="mt-4 max-w-[78%] text-[clamp(1.14rem,4.2vw,1.38rem)] leading-[1.12] tracking-[-0.01em] text-white/92 [font-family:'Cormorant_Garamond',serif]">{service.text}</p>
                      </div>
                    </div>
                  </div>
                  <div class="flex flex-1 flex-col md:mx-auto md:w-full md:max-w-[460px] xl:max-w-[480px] 2xl:max-w-[520px]">
                    <h3 class="mt-8 hidden max-w-[280px] text-[clamp(22px,1.6vw+16px,38px)] font-semibold uppercase leading-[1.06] transition-colors duration-300 group-hover:text-[#8f6c38] md:block [font-family:'Cormorant_Garamond',serif]">{service.title}</h3>
                    <p class="mt-6 hidden max-w-[340px] flex-1 text-[clamp(14px,0.6vw+12px,20px)] leading-[1.55] text-[#2f2f2c] md:block [font-family:'Cormorant_Garamond',serif]">{service.text}</p>
                    <div class="relative z-20 mt-5 flex items-center justify-center gap-8 px-4 text-[clamp(12px,0.45vw+10px,16px)] uppercase tracking-[1.2px] [font-family:'JetBrains_Mono',monospace] md:mt-auto md:justify-between md:gap-5 md:px-0 md:pt-8 xl:px-0 2xl:px-0">
                      <ServiceOrderModal client:idle serviceTitle={service.title} triggerLabel="заказать" triggerClassName="inline-flex h-12 min-w-[144px] items-center justify-center leading-none bg-[#050505] px-6 text-[clamp(13px,0.5vw+10px,17px)] uppercase tracking-[1.2px] text-white transition duration-300 ease-out hover:bg-[#1f1f1f] [font-family:'JetBrains_Mono',monospace] xl:min-w-[172px] xl:px-8" />
                      <a href={serviceHrefByTitle[service.title] ?? "/services"} class="inline-flex h-12 min-w-[144px] items-center justify-center border border-[#b8b2a8] px-6 leading-none text-[clamp(13px,0.5vw+10px,17px)] uppercase tracking-[1.2px] text-[#2d2d29] transition duration-300 ease-out hover:border-[#a9a39a] hover:text-[#8f6c38] [font-family:'JetBrains_Mono',monospace] xl:min-w-[172px] xl:px-8">подробнее</a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="steps" class="bg-[#0d0d0b] px-3 py-14 text-[#e1ddd6] sm:px-5 md:px-10 md:py-20">
          <div class="mx-auto max-w-[1480px] 2xl:max-w-[1860px]">
            <h2 class="text-[clamp(32px,3.2vw,68px)] leading-[0.95] text-[#e1ddd6] [font-family:'Cormorant_Garamond',serif]">Любая задача в 4 этапа</h2>
            <div class="relative mt-9 space-y-4 md:hidden">
              <div class="pointer-events-none absolute left-1/2 top-4 h-[calc(100%-2rem)] w-px -translate-x-1/2 bg-[#242420]" />
              {steps.map(([image, title, text], index) => {
                const isRight = index % 2 === 1;
                return (
                  <article
                    data-home-steps-reveal
                    data-reveal-delay={index * 120}
                    class={`home-steps-reveal ${isRight ? "from-right ml-auto text-right" : "from-left mr-auto text-left"} relative z-[1] w-[82%] rounded-[24px] border border-[#252520] bg-[#11110f] px-5 py-5 shadow-[0_16px_34px_rgba(0,0,0,0.28)]`}
                  >
                    <div class={`flex items-center gap-3 ${isRight ? "justify-end" : "justify-start"}`}>
                      <span class="flex h-11 w-11 items-center justify-center rounded-full border border-[#2d2c28] bg-[#0d0d0b]"><img src={image} alt="" loading="lazy" decoding="async" width="44" height="44" class="h-7 w-7 object-contain opacity-90 [filter:brightness(0)_invert(92%)_sepia(7%)_saturate(172%)_hue-rotate(357deg)_brightness(96%)_contrast(90%)]" /></span>
                      <span class="text-[11px] uppercase tracking-[0.2em] text-[#807d75] [font-family:'JetBrains_Mono',monospace]">0{index + 1}</span>
                    </div>
                    <h3 class="mt-4 text-[26px] leading-none text-[#e1ddd6] [font-family:'Cormorant_Garamond',serif]">{title}</h3>
                    <p class="mt-2 text-[15px] leading-[1.45] text-[#d6d2ca]">{text}</p>
                  </article>
                );
              })}
            </div>
            <div class="mt-10 hidden justify-items-center gap-8 md:grid sm:mt-12 sm:grid-cols-2 sm:justify-items-stretch sm:gap-x-8 sm:gap-y-10 xl:grid-cols-4 xl:gap-12">
              {steps.map(([image, title, text]) => (
                <article class="max-w-[320px] text-center transition duration-500 ease-out hover:-translate-y-1 sm:max-w-none sm:text-left">
                  <img src={image} alt="" loading="lazy" decoding="async" width="48" height="48" class="mx-auto h-11 w-11 object-contain opacity-90 transition duration-300 ease-out hover:scale-110 sm:mx-0 sm:h-12 sm:w-12 [filter:brightness(0)_invert(92%)_sepia(7%)_saturate(172%)_hue-rotate(357deg)_brightness(96%)_contrast(90%)]" />
                  <h3 class="mt-4 text-[clamp(20px,1.1vw+16px,32px)] leading-none text-[#e1ddd6] [font-family:'Cormorant_Garamond',serif]">{title}</h3>
                  <p class="mt-2 text-[clamp(14px,0.55vw+12px,19px)] leading-[1.6] text-[#e1ddd6]">{text}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="blog" class="px-3 py-16 sm:px-5 md:px-10 md:py-24">
          <div class="mx-auto max-w-[1480px] 2xl:max-w-[1860px]">
            <div class="flex items-end justify-between gap-3">
