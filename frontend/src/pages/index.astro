              </div>
              <div class="hidden gap-6 md:grid lg:grid-cols-12 xl:gap-8">
                {blogTopRow.map((article, index) => (
                  <article data-home-blog-reveal data-reveal-delay={index * 120} class={`home-blog-reveal group relative flex h-full flex-col overflow-hidden border border-[#ddd6cc] bg-white ${index === 0 ? "md:col-span-8" : "md:col-span-4"}`}>
                    <a href="/news" aria-label={`Открыть новость: ${article.title}`} class="flex h-full flex-col">
                      <img src={article.image} alt="" loading="lazy" decoding="async" width="1200" height="760" class={`${index === 0 ? "aspect-[16/9] md:h-[300px]" : "aspect-[4/3] md:h-[300px]"} w-full object-cover`} />
                      <div class="flex h-full flex-col border-t border-[#ddd6cc] bg-[#e1ddd6] px-5 py-4 md:min-h-[188px] md:px-6 md:py-5">
                        <div class="grid grid-cols-[minmax(0,1fr)_auto] items-start gap-4 md:gap-5">
                          <h3 class="pr-2 text-[clamp(24px,1.55vw,42px)] font-semibold leading-[0.9] tracking-[-0.03em] text-[#0d0d0b] [font-family:'Cormorant_Garamond',serif]">{article.title}</h3>
                          <span class="shrink-0 pt-1 text-[clamp(12px,0.55vw+10px,17px)] leading-none text-[#9a9891]">{article.publishedLabel}</span>
