        </section>

        <HomeReviewsIsland client:load />
        <HomeConsultationIsland client:idle />
      </div>
      <SiteFooter />
    </main>
  </body>
  <script is:inline>
    const desktopMedia = window.matchMedia("(min-width: 768px)");
    const serviceCards = document.querySelectorAll("[data-service-card]");

    const stopVideo = (video) => {
      video.pause();
      video.currentTime = 0;
    };

    serviceCards.forEach((card) => {
      const video = card.querySelector("[data-service-video]");
      if (!(video instanceof HTMLVideoElement)) return;

      card.addEventListener("mouseenter", () => {
        if (!desktopMedia.matches) return;
        void video.play().catch(() => {});
      });

      card.addEventListener("mouseleave", () => {
        if (!desktopMedia.matches) return;
        stopVideo(video);
      });
    });

    desktopMedia.addEventListener("change", (event) => {
      if (event.matches) return;
      document.querySelectorAll("[data-service-video]").forEach((video) => {
        if (video instanceof HTMLVideoElement) stopVideo(video);
      });
    });

    const aboutVideos = document.querySelectorAll("[data-about-video]");

    const shouldPlayAboutVideo = (video) => {
      const scope = video.getAttribute("data-about-video");
      if (scope === "desktop") return desktopMedia.matches;
      if (scope === "mobile") return !desktopMedia.matches;
      return true;
    };

    const normalizeInlineAutoplay = (video) => {
      video.muted = true;
      video.autoplay = true;
      video.loop = true;
      video.playsInline = true;
      video.setAttribute("muted", "");
      video.setAttribute("playsinline", "");
      video.setAttribute("webkit-playsinline", "");
    };

    const tryPlayInline = async (video) => {
      if (!shouldPlayAboutVideo(video)) return false;
      normalizeInlineAutoplay(video);
      try {
        await video.play();
        return true;
      } catch {
        return false;
      }
    };

    const bindFallbackGesture = (video) => {
      if (video.dataset.autoplayFallbackBound === "1") return;
      video.dataset.autoplayFallbackBound = "1";

      const retry = () => {
        void tryPlayInline(video);
      };

      window.addEventListener("touchstart", retry, { once: true, passive: true });
      window.addEventListener("click", retry, { once: true });
      document.addEventListener("visibilitychange", () => {
        if (!document.hidden) retry();
      });
    };

    const startAboutVideo = (video) => {
      void tryPlayInline(video).then((ok) => {
        if (!ok) bindFallbackGesture(video);
      });
    };

    aboutVideos.forEach((node) => {
      if (!(node instanceof HTMLVideoElement)) return;

      if (!("IntersectionObserver" in window)) {
        startAboutVideo(node);
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            startAboutVideo(node);
          }
        },
        { threshold: 0.25 },
      );

      observer.observe(node);
    });

    desktopMedia.addEventListener("change", () => {
      aboutVideos.forEach((node) => {
        if (!(node instanceof HTMLVideoElement)) return;
        if (shouldPlayAboutVideo(node)) {
          void tryPlayInline(node);
        } else {
          stopVideo(node);
        }
      });
    });

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const serviceRevealBlocks = document.querySelectorAll("[data-home-services-reveal]");

    const revealServiceBlock = (node) => {
      node.classList.add("is-visible");
    };

    const revealServiceBlockWithDelay = (node) => {
      const delay = Number(node.dataset.revealDelay ?? "0");
      if (delay > 0) {
        window.setTimeout(() => revealServiceBlock(node), delay);
        return;
      }
      revealServiceBlock(node);
    };

    if (prefersReducedMotion.matches) {
      serviceRevealBlocks.forEach((node) => {
        if (node instanceof HTMLElement) revealServiceBlock(node);
      });
    } else if ("IntersectionObserver" in window) {
      const serviceObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const node = entry.target;
            if (node instanceof HTMLElement) revealServiceBlockWithDelay(node);
            serviceObserver.unobserve(node);
          });
        },
        { threshold: 0.2, rootMargin: "0px 0px -8% 0px" },
      );

      serviceRevealBlocks.forEach((node) => {
        if (node instanceof HTMLElement) serviceObserver.observe(node);
      });
    } else {
      serviceRevealBlocks.forEach((node) => {
        if (node instanceof HTMLElement) revealServiceBlockWithDelay(node);
      });
    }

    const stepsRevealBlocks = document.querySelectorAll("[data-home-steps-reveal]");

    const revealStepsBlock = (node) => {
      node.classList.add("is-visible");
    };

    const revealStepsBlockWithDelay = (node) => {
      const delay = Number(node.dataset.revealDelay ?? "0");
      if (delay > 0) {
        window.setTimeout(() => revealStepsBlock(node), delay);
        return;
      }
      revealStepsBlock(node);
    };

    if (prefersReducedMotion.matches) {
      stepsRevealBlocks.forEach((node) => {
        if (node instanceof HTMLElement) revealStepsBlock(node);
      });
    } else if ("IntersectionObserver" in window) {
      const stepsObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const node = entry.target;
            if (node instanceof HTMLElement) revealStepsBlockWithDelay(node);
            stepsObserver.unobserve(node);
          });
        },
        { threshold: 0.25, rootMargin: "0px 0px -10% 0px" },
      );

      stepsRevealBlocks.forEach((node) => {
        if (node instanceof HTMLElement) stepsObserver.observe(node);
      });
    } else {
      stepsRevealBlocks.forEach((node) => {
        if (node instanceof HTMLElement) revealStepsBlockWithDelay(node);
      });
    }

    const blogRevealBlocks = document.querySelectorAll("[data-home-blog-reveal]");

    const revealBlogBlock = (node) => {
      node.classList.add("is-visible");
    };

    const revealBlogBlockWithDelay = (node) => {
      const delay = Number(node.dataset.revealDelay ?? "0");
      if (delay > 0) {
        window.setTimeout(() => revealBlogBlock(node), delay);
        return;
      }
      revealBlogBlock(node);
    };

    if (prefersReducedMotion.matches) {
      blogRevealBlocks.forEach((node) => {
        if (node instanceof HTMLElement) revealBlogBlock(node);
      });
    } else if ("IntersectionObserver" in window) {
      const blogObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const node = entry.target;
            if (node instanceof HTMLElement) revealBlogBlockWithDelay(node);
            blogObserver.unobserve(node);
          });
        },
        { threshold: 0.18, rootMargin: "0px 0px -10% 0px" },
      );

      blogRevealBlocks.forEach((node) => {
        if (node instanceof HTMLElement) blogObserver.observe(node);
      });
    } else {
      blogRevealBlocks.forEach((node) => {
        if (node instanceof HTMLElement) revealBlogBlockWithDelay(node);
      });
    }
  </script>
</html>
