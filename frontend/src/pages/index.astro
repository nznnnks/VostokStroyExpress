                          <span class="shrink-0 pt-1 text-[12px] leading-none text-[#9a9891]">{mobileBlogTail.publishedLabel}</span>
                        </div>
                        <p class="mt-3 text-[13px] leading-[1.35] text-[#30302c] line-clamp-2">{mobileBlogTail.text}</p>
                        <div class="mt-4 flex justify-end">
                          <span class="inline-flex h-11 min-w-[132px] items-center justify-center bg-[#1a1a1a] px-6 text-[11px] uppercase tracking-[1.2px] text-white [font-family:'JetBrains_Mono',monospace]">читать</span>
