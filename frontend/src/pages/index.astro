                  <article data-home-blog-reveal data-reveal-delay={(index + 2) * 120} class={`home-blog-reveal group relative flex h-full flex-col overflow-hidden border border-[#ddd6cc] bg-white ${index === 1 ? "md:col-span-8" : "md:col-span-4"}`}>
                    <a href="/news" aria-label={`Открыть новость: ${article.title}`} class="flex h-full flex-col">
                      <img src={article.image} alt="" loading="lazy" decoding="async" width="1200" height="760" class={`${index === 1 ? "aspect-[16/9] md:h-[260px]" : "aspect-[4/3] md:h-[260px]"} w-full object-cover`} />
                      <div class="flex h-full flex-col border-t border-[#ddd6cc] bg-[#e1ddd6] px-5 py-4 md:min-h-[188px] md:px-6 md:py-5">
