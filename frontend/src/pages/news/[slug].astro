---
import "../../styles/global.css";
import SiteHeader from "../../components/SiteHeader";
import SiteFooter from "../../components/SiteFooter";
import { loadNewsPostBySlug } from "../../lib/backend-api";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const post = await loadNewsPostBySlug(slug);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post?.metaTitle ?? post?.title ?? "Новость"}</title>
    <meta name="description" content={post?.metaDescription ?? post?.excerpt ?? "Новости компании и отрасли."} />
    {post?.metaKeywords ? <meta name="keywords" content={post.metaKeywords} /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@400;500&family=Jaldi:wght@400;700&family=JetBrains+Mono:wght@400&family=Manrope:wght@200;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="bg-white text-[#111] [font-family:DM_Sans,Manrope,'Liberation_Sans',sans-serif]">
      <SiteHeader client:load />
      <section class="px-4 py-10 md:px-10 md:py-14">
        <article class="mx-auto max-w-[1180px]">
          <p class="text-[13px] uppercase tracking-[1.5px] text-[#7a7a75] [font-family:Jaldi,'JetBrains_Mono',monospace]">
            <a href="/" class="hover:text-[#111]">Главная</a>
            <span class="mx-2 text-[#b5b2ab]">/</span>
            <a href="/news" class="hover:text-[#111]">Новости</a>
            <span class="mx-2 text-[#b5b2ab]">/</span>
            <span>{post?.category ?? "Новость"}</span>
          </p>
          <h1 class="mt-8 max-w-[900px] text-[56px] leading-[0.92] md:text-[92px] [font-family:'Cormorant_Garamond',serif]">{post?.title ?? "Материал не найден"}</h1>
          {post ? (
            <>
              {post.image ? <img src={post.image} alt="" aria-hidden="true" width="1200" height="760" class="mt-10 aspect-[16/9] w-full object-cover" /> : null}
              {post.images?.length > 1 ? (
                <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                  {post.images.slice(1).map((image) => (
                    <img src={image} alt="" aria-hidden="true" width="800" height="520" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async" />
                  ))}
                </div>
              ) : null}
              <div class="mt-10 space-y-8 text-[20px] leading-[1.8] text-[#5d5d58] md:text-[24px]">
                {post.content.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </>
          ) : (
            <div class="mt-10 border border-[#e8e3db] px-8 py-12 text-[20px] text-[#5d5d58]">Материал не найден.</div>
          )}
          <div class="mt-10">
            <a href="/news" class="inline-flex h-14 items-center justify-center border border-[#111] px-8 text-[14px] uppercase tracking-[1.5px] text-[#111] [font-family:Jaldi,'JetBrains_Mono',monospace]">
              Назад к блогу
            </a>
          </div>
        </article>
      </section>
      <SiteFooter />
    </main>
  </body>
</html>
