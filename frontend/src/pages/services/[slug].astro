---
import "../../styles/global.css";
import SiteHeader from "../../components/SiteHeader";
import SiteFooter from "../../components/SiteFooter";
import ServiceOrderModal from "../../components/ServiceOrderModal";
import { loadServiceBySlug } from "../../lib/backend-api";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const service = await loadServiceBySlug(slug);

if (!service) {
  return Astro.redirect("/services");
}

const serviceGalleryImages = [
  ...new Set([
    ...service.detailImages,
    service.image,
    "/image/services-card-bg-2026.png",
    "/image/services-1.png",
    "/image/services-2.png",
    "/image/services-3.png",
    "/image/steps-1.png",
    "/image/steps-2.png",
    "/image/steps-3.png",
    "/image/steps-4.png",
  ]),
].slice(0, 4);

const serviceProcessSteps = service.bullets.map((bullet, index) => ({
  title: bullet,
  text:
    index === 0
      ? "Фиксируем исходное состояние системы, проверяем шумы, вибрации и точки, где оборудование конфликтует с интерьером."
      : index === 1
        ? "Настраиваем трассы, крепления и воздуховоды так, чтобы система работала устойчиво и без лишнего механического давления."
        : index === 2
          ? "Подбираем тихие режимы работы, корректируем сценарии и проверяем комфорт в реальных условиях эксплуатации."
          : "Финально калибруем систему на объекте и передаем понятную логику дальнейшей эксплуатации.",
}));
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{service.metaTitle ?? service.title}</title>
    <meta name="description" content={service.metaDescription ?? service.lead} />
    {service.metaKeywords ? <meta name="keywords" content={service.metaKeywords} /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@400;500&family=Jaldi:wght@400;700&family=JetBrains+Mono:wght@400&family=Manrope:wght@200;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="bg-white text-[#111] [font-family:DM_Sans,Manrope,'Liberation_Sans',sans-serif]">
      <SiteHeader client:load />
      <section class="px-4 py-8 md:px-10 md:py-10">
        <div class="mx-auto max-w-[1480px]">
          <p class="breadcrumb-nav uppercase tracking-[1.5px] text-[#7a7a75] [font-family:Jaldi,'JetBrains_Mono',monospace]">
            <a href="/" class="hover:text-[#111]">Главная</a>
            <span class="mx-2 text-[#b5b2ab]">/</span>
            <a href="/services" class="hover:text-[#111]">Услуги</a>
            <span class="mx-2 text-[#b5b2ab]">/</span>
            <span>{service.title}</span>
          </p>
          <div class="mt-6 grid gap-7 md:mt-6 md:gap-8 xl:grid-cols-[0.9fr_1.1fr] xl:items-center">
            <div class="mx-auto aspect-square w-full max-w-[470px] overflow-hidden rounded-[22px] bg-[#10100f] shadow-[0_18px_44px_rgba(0,0,0,0.14)] 2xl:max-w-[520px]">
              <img src="/image/services-card-bg-2026.png" alt="" aria-hidden="true" width="1024" height="768" class="h-full w-full object-cover opacity-90" />
            </div>
            <div>
              <h1 class="max-w-[920px] break-words text-[clamp(2.2rem,7vw,4.6rem)] leading-[0.92] [font-family:'Cormorant_Garamond',serif] 2xl:text-[clamp(3rem,4.35vw,6rem)]">{service.heroTitle}</h1>
              <p class="mt-4 max-w-[900px] border-l border-[#b99863]/55 pl-4 text-[clamp(1rem,3.9vw,1.42rem)] leading-[1.5] text-[#555550] md:mt-6 md:pl-6 md:leading-[1.58] 2xl:text-[clamp(1.18rem,1.1vw,1.75rem)]">{service.lead}</p>
              <div class="mt-5 grid gap-2 md:mt-7 md:gap-3">
                {service.bullets.map((bullet) => (
                  <div class="border border-[#e8e3db] bg-[#e8e4dc]/35 px-4 py-3 text-[14px] leading-5 text-[#5f5f5a] md:px-5 md:py-4 md:text-[15px] md:leading-6 2xl:px-6 2xl:py-4 2xl:text-[18px] 2xl:leading-7">{bullet}</div>
                ))}
              </div>
              <div class="mt-5 flex flex-wrap gap-3 md:mt-7 md:gap-4">
                <ServiceOrderModal client:load serviceTitle={service.title} />
                <a href="/services" class="inline-flex h-12 items-center justify-center border border-[#111] px-6 text-[13px] uppercase tracking-[1.2px] text-[#111] md:h-14 md:px-8 md:text-[14px] md:tracking-[1.5px] [font-family:Jaldi,'JetBrains_Mono',monospace]">
                  Все услуги
                </a>
              </div>
            </div>
          </div>

          <div class="mt-8 grid gap-8 md:mt-10 md:gap-12 xl:grid-cols-[0.9fr_1.1fr] xl:items-stretch xl:gap-32 2xl:gap-40">
            <div class="service-detail-copy">
              <p class="text-[13px] uppercase tracking-[2px] text-[#9a9993] [font-family:Jaldi,'JetBrains_Mono',monospace]">Полное описание</p>
              <h2 class="mt-3 text-[clamp(2rem,6vw,3.35rem)] leading-[1.03] [font-family:'Cormorant_Garamond',serif] 2xl:text-[clamp(2.8rem,3.2vw,4.4rem)]">{service.detailTitle}</h2>
              <p class="mt-4 max-w-[820px] text-[16px] leading-[1.58] text-[#5f5f5a] md:mt-5 md:text-[18px] md:leading-[1.55] 2xl:text-[22px] 2xl:leading-[1.62]">{service.detailText}</p>
              <p class="mt-4 max-w-[820px] text-[15px] leading-[1.6] text-[#6a6a65] md:text-[16px] 2xl:text-[19px] 2xl:leading-[1.7]">
                Работы ведем поэтапно: сначала находим источник шума и вибраций, затем корректируем инженерные узлы, проверяем режимы работы и доводим систему до спокойной эксплуатации на объекте.
              </p>
              <ul class="mt-5 space-y-2 text-[15px] leading-6 text-[#6a6a65] md:mt-6 md:text-[15px] md:leading-6 2xl:space-y-3 2xl:text-[18px] 2xl:leading-8">
                {service.deliverables.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#b8a06a]" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-6 grid gap-3 md:grid-cols-2 2xl:mt-8 2xl:gap-5">
                {serviceProcessSteps.map((step, index) => (
                  <article class="border border-[#e8e3db] bg-[#e8e4dc]/35 p-4 2xl:p-6">
                    <p class="text-[12px] uppercase tracking-[2px] text-[#9a9993] [font-family:Jaldi,'JetBrains_Mono',monospace] 2xl:text-[13px]">Шаг {index + 1}</p>
                    <h3 class="mt-2 text-[21px] leading-[1.05] [font-family:'Cormorant_Garamond',serif] 2xl:text-[30px]">{step.title}</h3>
                    <p class="mt-3 text-[14px] leading-5 text-[#6a6a65] 2xl:text-[17px] 2xl:leading-7">{step.text}</p>
                  </article>
                ))}
              </div>
            </div>
            <div class="service-gallery-frame">
              <div class="service-gallery">
                {serviceGalleryImages.map((src, index) => (
                  <div class={`service-gallery-item service-gallery-item-${index + 1}`}>
                    <img src={src} alt="" aria-hidden="true" width="600" height="600" class="h-full w-full object-cover transition duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]" loading={index === 0 ? "eager" : "lazy"} />
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
      <SiteFooter />
    </main>
    <style>
      .service-gallery-frame {
        position: relative;
        width: 100%;
        min-height: clamp(430px, 56vw, 650px);
        justify-self: start;
        align-self: stretch;
        overflow: hidden;
        min-width: 0;
      }

      .service-gallery {
        position: absolute;
        inset: 0;
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
        gap: 18px;
        height: auto;
        max-height: none;
        min-height: 0;
        width: 100%;
        min-width: 0;
        overflow: hidden;
        transition:
          grid-template-columns 700ms cubic-bezier(0.22, 1, 0.36, 1),
          grid-template-rows 700ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      .service-gallery:has(.service-gallery-item-1:hover) {
        grid-template-columns: minmax(0, 1.32fr) minmax(0, 0.68fr);
        grid-template-rows: minmax(0, 1.32fr) minmax(0, 0.68fr);
      }

      .service-gallery:has(.service-gallery-item-2:hover) {
        grid-template-columns: minmax(0, 0.68fr) minmax(0, 1.32fr);
        grid-template-rows: minmax(0, 1.32fr) minmax(0, 0.68fr);
      }

      .service-gallery:has(.service-gallery-item-3:hover) {
        grid-template-columns: minmax(0, 1.32fr) minmax(0, 0.68fr);
        grid-template-rows: minmax(0, 0.68fr) minmax(0, 1.32fr);
      }

      .service-gallery:has(.service-gallery-item-4:hover) {
        grid-template-columns: minmax(0, 0.68fr) minmax(0, 1.32fr);
        grid-template-rows: minmax(0, 0.68fr) minmax(0, 1.32fr);
      }

      .service-gallery-item {
        height: 100%;
        min-height: 0;
        min-width: 0;
        overflow: hidden;
        border: 1px solid #e8e3db;
        border-radius: 22px;
        background: #f7f5f1;
        box-shadow: 0 16px 34px rgba(0, 0, 0, 0.08);
      }

      .service-gallery-item:hover img {
        transform: scale(1.04);
      }

      .service-gallery-item img {
        display: block;
        min-height: 0;
        min-width: 0;
      }

      @media (min-width: 768px) {
        .service-gallery-frame {
          width: 100%;
          min-height: clamp(500px, 54vw, 700px);
        }
      }

      @media (min-width: 1280px) {
        .service-gallery-frame {
          width: min(100%, 680px);
          min-height: clamp(430px, 31vw, 520px);
        }
      }

      @media (max-width: 639px) {
        .service-gallery-frame {
          position: static;
          height: auto;
          min-height: 0;
          width: 100%;
        }

        .service-gallery {
          position: static;
          grid-template-rows: none;
          grid-template-columns: 1fr;
        }

        .service-gallery:has(.service-gallery-item-1:hover),
        .service-gallery:has(.service-gallery-item-2:hover),
        .service-gallery:has(.service-gallery-item-3:hover),
        .service-gallery:has(.service-gallery-item-4:hover) {
          grid-template-columns: 1fr;
          grid-template-rows: none;
        }

        .service-gallery-item {
          aspect-ratio: 4 / 3;
        }
      }
    </style>
  </body>
</html>
