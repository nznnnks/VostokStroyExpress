---
import "../../styles/global.css";
import SiteHeader from "../../components/SiteHeader";
import SiteFooter from "../../components/SiteFooter";
import { loadServiceBySlug } from "../../lib/backend-api";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const service = await loadServiceBySlug(slug);

if (!service) {
  return Astro.redirect("/services");
}
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{service.metaTitle ?? service.title}</title>
    <meta name="description" content={service.metaDescription ?? service.lead} />
    {service.metaKeywords ? <meta name="keywords" content={service.metaKeywords} /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@400;500&family=Jaldi:wght@400;700&family=JetBrains+Mono:wght@400&family=Manrope:wght@200;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="bg-white text-[#111] [font-family:DM_Sans,Manrope,'Liberation_Sans',sans-serif]">
      <SiteHeader client:load />
      <section class="px-4 py-10 md:px-10 md:py-14">
        <div class="mx-auto max-w-[1480px]">
          <p class="text-[13px] uppercase tracking-[1.5px] text-[#7a7a75] [font-family:Jaldi,'JetBrains_Mono',monospace]">
            <a href="/" class="hover:text-[#111]">Главная</a>
            <span class="mx-2 text-[#b5b2ab]">/</span>
            <a href="/services" class="hover:text-[#111]">Услуги</a>
            <span class="mx-2 text-[#b5b2ab]">/</span>
            <span>{service.title}</span>
          </p>
          <div class="mt-8 grid gap-10 xl:grid-cols-[0.9fr_1.1fr] xl:items-center">
            <img src={service.image} alt="" aria-hidden="true" width="800" height="800" class="mx-auto aspect-square w-full max-w-[420px] object-contain" />
            <div>
              <h1 class="max-w-[900px] text-[56px] leading-[0.92] md:text-[92px] [font-family:'Cormorant_Garamond',serif]">{service.heroTitle}</h1>
              <p class="mt-8 max-w-[900px] text-[20px] leading-[1.65] text-[#5d5d58] md:text-[26px]">{service.lead}</p>
              <div class="mt-10 grid gap-4">
                {service.bullets.map((bullet) => (
                  <div class="border border-[#e8e3db] px-6 py-5 text-[17px] leading-7 text-[#5f5f5a]">{bullet}</div>
                ))}
              </div>
              <div class="mt-10 flex flex-wrap gap-4">
                <a href="/checkout" class="inline-flex h-14 items-center justify-center bg-[#111] px-8 text-[14px] uppercase tracking-[1.5px] text-white [font-family:Jaldi,'JetBrains_Mono',monospace]">
                  Рассчитать стоимость
                </a>
                <a href="/services" class="inline-flex h-14 items-center justify-center border border-[#111] px-8 text-[14px] uppercase tracking-[1.5px] text-[#111] [font-family:Jaldi,'JetBrains_Mono',monospace]">
                  Все услуги
                </a>
              </div>
            </div>
          </div>

          <div class="mt-20 grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
            <div>
              <h2 class="text-[40px] leading-[1.05] md:text-[56px] [font-family:'Cormorant_Garamond',serif]">{service.detailTitle}</h2>
              <p class="mt-6 text-[18px] leading-[1.7] text-[#5f5f5a] md:text-[22px]">{service.detailText}</p>
              <ul class="mt-8 space-y-4 text-[16px] leading-7 text-[#6a6a65]">
                {service.deliverables.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#b8a06a]" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="grid gap-6 sm:grid-cols-2">
              {service.detailImages.map((src, index) => (
                <div class="overflow-hidden border border-[#e8e3db] bg-[#f7f5f1]">
                  <img src={src} alt="" aria-hidden="true" width="600" height="600" class="h-full w-full object-cover" loading={index === 0 ? "eager" : "lazy"} />
                </div>
              ))}
            </div>
          </div>

          <div class="mt-20 grid gap-10 md:grid-cols-3">
            {service.bullets.map((bullet, index) => (
              <div class="border border-[#e8e3db] p-7">
                <p class="text-[14px] uppercase tracking-[2px] text-[#9a9993] [font-family:Jaldi,'JetBrains_Mono',monospace]">Шаг {index + 1}</p>
                <h3 class="mt-4 text-[26px] leading-[1.1] [font-family:'Cormorant_Garamond',serif]">{bullet}</h3>
                <p class="mt-4 text-[16px] leading-7 text-[#6a6a65]">
                  Формируем результатный блок работ с учетом архитектуры, инженерных условий и будущих сценариев использования.
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>
      <SiteFooter />
    </main>
  </body>
</html>
