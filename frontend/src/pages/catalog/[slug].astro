---
import { ProductPage } from "../../components/ProductPage";
import { loadCatalogProductBySlug } from "../../lib/backend-api";
import GlobalPreloader from "../../components/GlobalPreloader.astro";
import "../../styles/global.css";

export const prerender = false;

const slug = Astro.params.slug ?? "";
let product;
let relatedProducts = [];
let allProducts = [];

try {
  const result = await loadCatalogProductBySlug(slug);
  product = result.product;
  relatedProducts = result.relatedProducts;
  allProducts = result.allProducts ?? [];
} catch {
  return Astro.redirect("/catalog");
}

function normalizeText(value: string) {
  return value.replace(/\s+/g, " ").trim();
}

function buildAutoDescription() {
  const descriptionParts = Array.isArray(product.description) ? product.description : [];
  const base =
    descriptionParts.find((item) => normalizeText(item).length > 0) ??
    [product.title, product.brandLabel, product.category, product.type].filter(Boolean).join(". ");
  const normalized = normalizeText(base);

  if (normalized.length <= 170) {
    return normalized;
  }

  return `${normalized.slice(0, 167).trimEnd()}...`;
}

function buildAutoKeywords() {
  const values = [
    product.title,
    product.category,
    product.type,
    product.brandLabel,
    product.article,
  ]
    .map((item) => normalizeText(item ?? ""))
    .filter(Boolean);

  return Array.from(new Set(values)).join(", ");
}

const pageTitle = normalizeText(product.metaTitle ?? product.title);
const pageDescription = normalizeText(product.metaDescription ?? buildAutoDescription());
const pageKeywords = normalizeText(product.metaKeywords ?? buildAutoKeywords());
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={pageKeywords} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@400;500&family=Jaldi:wght@400;700&family=JetBrains+Mono:wght@400&family=Manrope:wght@200;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <GlobalPreloader />
    <ProductPage client:load product={product} relatedProducts={relatedProducts} allProducts={allProducts} />
  </body>
</html>
